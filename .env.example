# collaboration-ai dev environment.
# Copy to `.env` and adjust as needed.

# --- Backend (hof-engine app) ---
DATABASE_URL=postgresql+psycopg://collabai:collabai@localhost:5434/collabai
REDIS_URL=redis://localhost:6381/0
APP_PORT=8200

# --- Attachments ---
S3_ENDPOINT_URL=http://localhost:9100
S3_BUCKET_NAME=collabai-attachments
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=collabai
AWS_SECRET_ACCESS_KEY=collabai-dev-password

# --- Email (dev: Mailhog) ---
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_FROM=collabai@localhost

# --- Web push (VAPID) ---
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:dev@collaboration-ai.local

# --- Auth ---
SESSION_SECRET=dev-session-secret-change-me
ARGON2_PEPPER=dev-pepper-change-me
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# --- Agents ---
DEFAULT_AGENT_BUDGET_MESSAGES_PER_HOUR=200
DEFAULT_STAGING_POLICY=agent-messages-require-approval
