{
  "name": "@collabai/hofos-ui",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "*.css",
    "dist/*.css"
  ],
  "scripts": {
    "build": "vite build && cp src/index.d.ts dist/index.d.ts",
    "build:dist": "pnpm run build",
    "typecheck": "echo \"types are generated from src/index.d.ts\"",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "lucide-react": "^0.574.0",
    "react-router": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "@collabai/ui": "workspace:*",
    "@collabai/design-tokens": "workspace:*"
  },
  "license": "MIT"
}
