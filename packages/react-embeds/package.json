{
  "name": "@collabai/react-embeds",
  "version": "0.1.0",
  "private": false,
  "description": "Embeddable React surfaces (<ChatPanel />, <ChannelView />, <AgentInbox />) for hosting collaboration-ai inside other apps (e.g. hof-os data-app).",
  "main": "./src/index.ts",
