{
  "name": "@collabai/react-embeds",
  "version": "0.4.1",
  "private": false,
  "type": "module",
  "description": "Embeddable React surfaces (<ChatPanel />, <ChannelView />, <AgentInbox />, headless composables) for hosting collaboration-ai inside other apps (e.g. hof-os data-app).",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./contract": {
      "types": "./src/contract.ts",
      "import": "./dist/contract.js"
    },
    "./app": {
      "types": "./src/CollabAiApp.tsx",
      "import": "./dist/CollabAiApp.js"
    },
    "./providers": {
      "types": "./src/AppProviders.tsx",
      "import": "./dist/AppProviders.js"
    },
    "./commands": {
      "types": "./src/commands.ts",
      "import": "./dist/commands.js"
    },
    "./channel-list": {
      "types": "./src/CollabAiChannelList.tsx",
      "import": "./dist/CollabAiChannelList.js"
    },
    "./channel": {
      "types": "./src/CollabAiChannel.tsx",
      "import": "./dist/CollabAiChannel.js"
    },
    "./thread-pane": {
      "types": "./src/CollabAiThreadPane.tsx",
      "import": "./dist/CollabAiThreadPane.js"
    },
    "./activity-pane": {
      "types": "./src/CollabAiActivityPane.tsx",
      "import": "./dist/CollabAiActivityPane.js"
    },
    "./search-input": {
      "types": "./src/CollabAiSearchInput.tsx",
      "import": "./dist/CollabAiSearchInput.js"
    },
    "./components/attachment-viewer": {
      "types": "./src/components/AttachmentViewer.tsx",
      "import": "./dist/components/AttachmentViewer.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@collabai/design-tokens": "workspace:*",
    "@collabai/ui": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "@tanstack/react-query": "^5.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "esbuild": "^0.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.0",
    "typescript": "^5.6.3",
    "zustand": "^5.0.2"
  },
  "license": "MIT"
}
