{
  "name": "@collabai/react-embeds",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Embeddable React surfaces (<ChatPanel />, <ChannelView />, <AgentInbox />) for hosting collaboration-ai inside other apps (e.g. hof-os data-app).",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./contract": {
      "types": "./src/contract.ts",
      "import": "./dist/contract.js"
    },
    "./components/attachment-viewer": {
      "types": "./src/components/AttachmentViewer.tsx",
      "import": "./dist/components/AttachmentViewer.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@collabai/design-tokens": "workspace:*",
    "@collabai/ui": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "esbuild": "^0.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.3"
  },
  "license": "MIT"
}
