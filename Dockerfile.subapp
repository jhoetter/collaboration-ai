# Structural WP-4 subapp Dockerfile stub for CollaborationAI.
# Replace this with the product's production image build once the full
# standalone-subdomain conversion is implemented.
FROM node:20-bookworm-slim
WORKDIR /app
COPY hof-module.json tools.json ./
COPY cli/chat-agent /usr/local/bin/chat-agent
RUN chmod +x /usr/local/bin/chat-agent
ENV HOF_SUBAPP_NAME=collabai HOF_SUBAPP_AUTH_MODE=inherit
EXPOSE 8300
CMD ["sh", "-c", "while true; do sleep 3600; done"]
