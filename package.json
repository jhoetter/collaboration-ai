{
  "name": "collaboration-ai",
  "version": "0.4.0",
  "private": true,
  "description": "collaboration-ai — AI-native, event-sourced team chat platform. Backend on hof-engine (Python + FastAPI + Postgres + Redis), web UI + agent CLI built per spec/.",
  "scripts": {
    "postinstall": "node scripts/ensure-officeai-react-editors.cjs",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:root": "eslint \"packages/**/*.{ts,tsx}\"",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "architecture": "node scripts/check-architecture.mjs",
    "hofos:check": "node scripts/check-hofos-ui-contract.mjs",
    "hofos:harness": "HOFOS_MODE=1 pnpm --filter @collabai/web build && node scripts/check-hofos-harness-smoke.mjs",
    "export:hofos-ui": "node scripts/export-hofos-ui.mjs",
    "verify": "pnpm format:check && pnpm lint:root && pnpm architecture && pnpm run hofos:check && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.13.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.3.3",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
