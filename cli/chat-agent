#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
from datetime import datetime, timezone

VERSION = "0.1.0"


def emit(ok: bool, result: dict, error: str | None = None) -> int:
    print(
        json.dumps(
            {
                "ok": ok,
                "result": result if ok else None,
                "error": error,
                "meta": {
                    "cli": "chat-agent",
                    "version": VERSION,
                    "emitted_at": datetime.now(timezone.utc).isoformat(),
                },
            },
            sort_keys=True,
        )
    )
    return 0 if ok else 1


def main() -> int:
    parser = argparse.ArgumentParser(prog="chat-agent")
    parser.add_argument("--version", action="store_true")
    sub = parser.add_subparsers(dest="group")
    sub.add_parser("status")
    channel = sub.add_parser("channel")
    channel_sub = channel.add_subparsers(dest="action")
    channel_sub.add_parser("list")
    message = sub.add_parser("message")
    message_sub = message.add_subparsers(dest="action")
    post = message_sub.add_parser("post")
    post.add_argument("--channel", required=True)
    post.add_argument("--text", required=True)
    message_sub.add_parser("search").add_argument("--query", required=True)
    dm = sub.add_parser("dm")
    dm_sub = dm.add_subparsers(dest="action")
    send = dm_sub.add_parser("send")
    send.add_argument("--to", required=True)
    send.add_argument("--text", required=True)
    args = parser.parse_args()

    if args.version:
        return emit(True, {"version": VERSION})
    if args.group == "status":
        return emit(True, {"module": "collabai", "status": "ready"})
    payload = {"module": "collabai", "group": args.group, "action": getattr(args, "action", None)}
    payload.update({k: v for k, v in vars(args).items() if k not in {"group", "action", "version"}})
    if args.group in {"channel", "message", "dm"} and args.action:
        return emit(True, payload)
    parser.print_help()
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
